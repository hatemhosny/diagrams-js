  "scripts": {
    "build": "vp run build:core && vp run build:providers && vp run build:fix",
    "build:core": "vp pack src/index.ts && node scripts/inline-chunks.mjs",
    "build:providers": "node scripts/build-providers.mjs",
    "build:fix": "vp check --fix",
    "dev": "vp build --watch",
    "docs": "cd docs && pnpm start",
    "docs:build": "cd docs && pnpm run build",
    "docs:install-build": "cd docs && pnpm install && pnpm run build",
    "test": "vp test",
    "check": "vp check",
    "fix": "vp check --fix",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "generate": "npx tsx scripts/generate.ts",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "changelog": "conventional-changelog -p angular -i ../CHANGELOG.md -s"
  },
